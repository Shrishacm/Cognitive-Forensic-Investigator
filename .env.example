# =============================================
# Cognitive Forensic Investigator — Config
# =============================================
# 1. Copy this file: cp .env.example .env
# 2. Generate a secret key:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
# 3. Paste the output as SECRET_KEY below
# =============================================

# Database
DATABASE_URL=sqlite:///./data/forensic.db

# File storage
CASES_DIR=./data/cases

# Application
APP_NAME=Cognitive Forensic Investigator
APP_VERSION=1.0.0
DEBUG=False

# Security — CHANGE THIS before running
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_KEY

# AI Model
# For GTX 1050 Ti (4GB VRAM): phi4-mini
# For M1/M2 Mac (8GB): llama3.2:3b
# For GPU with 8GB+ VRAM: qwen2.5:7b
OLLAMA_MODEL=llama3.2:3b

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434
